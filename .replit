modules = ["web", "nodejs-20", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["stripe:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Git remote"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Git add"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 node server.js"
waitForPort = 3001

[[workflows.workflow]]
name = "Git remote"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git remote remove origin 2>/dev/null; git remote add origin https://github.com/BetterhavemyMonet/MonetMoneyArcade.git && echo 'Remote set OK'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Git add"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git add . && git commit -m 'sync update' && git push origin main"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["node", "server.js"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[userenv]

[userenv.shared]
ADMIN_TOKEN = "71HOUJDVZu_23cFQ"
